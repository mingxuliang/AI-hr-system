# Backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_interview
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ai_interview
SECRET_KEY=change-me-to-a-long-random-string
APP_ENV=development
# Set to true only when you need local Swagger. Always disabled when APP_ENV=production.
ENABLE_API_DOCS=false
CORS_ORIGINS=http://localhost:5173

# Initial administrator created on first startup.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=admin123
INITIAL_ADMIN_NAME=System Admin

# LLM defaults. You can also configure these in the System Settings page.
LLM_PROVIDER=dashscope
LLM_MODEL=qwen3.5-plus
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Keep API metadata generic to avoid product fingerprinting
API_TITLE=API
API_DESCRIPTION=
API_VERSION=1.0.0

# Frontend
VITE_API_URL=/api
